# Copy to .env and adjust. All values are optional; defaults are for local dev only.

# Password required to sign in to the dashboard.
SENTINEL_PASSWORD=admin

# Secret used to sign session tokens. Change this to a long random string.
SENTINEL_SECRET=change-me-to-a-long-random-string

# Port the server listens on.
PORT=3000

# Path to the SQLite database file.
SENTINEL_DB=sentinel.db
